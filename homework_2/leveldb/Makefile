SHELL := /usr/bin/env bash

CXX ?= g++
CC ?= gcc
AR ?= ar

BUILD_DIR ?= build
OBJ_DIR := $(BUILD_DIR)/obj
BIN_DIR := $(BUILD_DIR)/bin
LIB_DIR := $(BUILD_DIR)/lib
GEN_INCLUDE_DIR := $(BUILD_DIR)/include
DATA_DIR := $(BUILD_DIR)/data
RESULT_DIR := $(BUILD_DIR)/results
PORT_CONFIG := $(GEN_INCLUDE_DIR)/port/port_config.h

CPPFLAGS += -I$(GEN_INCLUDE_DIR) -I. -Iinclude \
            -Ithird_party/googletest/googletest/include \
            -Ithird_party/googletest/googlemock/include \
            -DLEVELDB_PLATFORM_POSIX=1
CXXFLAGS ?= -std=c++17 -O2 -DNDEBUG
CFLAGS ?= -std=c11 -O2 -DNDEBUG
LDLIBS += -pthread

LEVELDB_SRCS := \
  db/builder.cc \
  db/c.cc \
  db/db_impl.cc \
  db/db_iter.cc \
  db/dbformat.cc \
  db/dumpfile.cc \
  db/filename.cc \
  db/log_reader.cc \
  db/log_writer.cc \
  db/memtable.cc \
  db/repair.cc \
  db/table_cache.cc \
  db/version_edit.cc \
  db/version_set.cc \
  db/write_batch.cc \
  table/block.cc \
  table/block_builder.cc \
  table/filter_block.cc \
  table/format.cc \
  table/iterator.cc \
  table/merger.cc \
  table/table.cc \
  table/table_builder.cc \
  table/two_level_iterator.cc \
  util/arena.cc \
  util/bloom.cc \
  util/cache.cc \
  util/coding.cc \
  util/comparator.cc \
  util/crc32c.cc \
  util/env.cc \
  util/env_posix.cc \
  util/filter_policy.cc \
  util/hash.cc \
  util/logging.cc \
  util/options.cc \
  util/status.cc \
  helpers/memenv/memenv.cc

LEVELDB_OBJS := $(LEVELDB_SRCS:%.cc=$(OBJ_DIR)/%.o)
LEVELDB_LIB := $(LIB_DIR)/libleveldb.a

DB_BENCH := $(BIN_DIR)/db_bench
TASK2_BIN := $(BIN_DIR)/leveldb_task2_test
POINT_GET_BIN := $(BIN_DIR)/leveldb_point_get_test
SCAN_BIN := $(BIN_DIR)/leveldb_scan_test
MIXED_RW_BIN := $(BIN_DIR)/leveldb_mixed_rw_test
C_TEST_BIN := $(BIN_DIR)/c_test

TASK_BINS := \
  $(DB_BENCH) \
  $(TASK2_BIN) \
  $(POINT_GET_BIN) \
  $(SCAN_BIN) \
  $(MIXED_RW_BIN) \
  $(C_TEST_BIN)

.PHONY: all run task1 task2 task3 clean help

all: $(TASK_BINS)

help:
	@printf '%s\n' \
	  'Targets:' \
	  '  make              Build LevelDB, db_bench, and all task executables' \
	  '  make run task1    Run task 1 db_bench parameter sweep' \
	  '  make run task2    Run task 2 tail-latency test' \
	  '  make run task3    Run task 3 point/scan/mixed tests in block and kv modes' \
	  '  make clean        Remove build outputs, generated DBs, and result logs'

run:
	@:

task1: $(DB_BENCH) | $(DATA_DIR) $(RESULT_DIR)
	@chmod +x run_db_bench.sh
	@LEVELDB_DB_BENCH="$(DB_BENCH)" \
	  LEVELDB_DATA_DIR="$(DATA_DIR)/task1" \
	  LEVELDB_RESULTS_DIR="$(RESULT_DIR)" \
	  ./run_db_bench.sh

task2: $(TASK2_BIN) | $(DATA_DIR) $(RESULT_DIR)
	@$(TASK2_BIN)

task3: $(POINT_GET_BIN) $(SCAN_BIN) $(MIXED_RW_BIN) | $(DATA_DIR) $(RESULT_DIR)
	@printf '\n== Point Get: Block Cache ==\n'
	@$(POINT_GET_BIN) --cache_mode=block
	@printf '\n== Point Get: KV Cache ==\n'
	@$(POINT_GET_BIN) --cache_mode=kv
	@printf '\n== Range Scan: Block Cache ==\n'
	@$(SCAN_BIN) --cache_mode=block
	@printf '\n== Range Scan: KV Cache ==\n'
	@$(SCAN_BIN) --cache_mode=kv
	@printf '\n== Mixed RW: Block Cache ==\n'
	@$(MIXED_RW_BIN) --cache_mode=block
	@printf '\n== Mixed RW: KV Cache ==\n'
	@$(MIXED_RW_BIN) --cache_mode=kv

$(LEVELDB_LIB): $(LEVELDB_OBJS) | $(LIB_DIR)
	$(AR) rcs $@ $^

$(OBJ_DIR)/%.o: %.cc $(PORT_CONFIG)
	@mkdir -p $(dir $@)
	$(CXX) $(CPPFLAGS) -DLEVELDB_COMPILE_LIBRARY $(CXXFLAGS) -c $< -o $@

$(OBJ_DIR)/db/c_test.o: db/c_test.c $(PORT_CONFIG)
	@mkdir -p $(dir $@)
	$(CC) $(CPPFLAGS) $(CFLAGS) -c $< -o $@

$(DB_BENCH): benchmarks/db_bench.cc util/histogram.cc util/testutil.cc $(LEVELDB_LIB) | $(BIN_DIR)
	$(CXX) $(CPPFLAGS) $(CXXFLAGS) benchmarks/db_bench.cc util/histogram.cc util/testutil.cc $(LEVELDB_LIB) -o $@ $(LDLIBS)

$(TASK2_BIN): leveldb_test_task2.cpp $(LEVELDB_LIB) | $(BIN_DIR)
	$(CXX) $(CPPFLAGS) $(CXXFLAGS) $< $(LEVELDB_LIB) -o $@ $(LDLIBS)

$(POINT_GET_BIN): leveldb_point_get_test.cpp kv_cache.h $(LEVELDB_LIB) | $(BIN_DIR)
	$(CXX) $(CPPFLAGS) $(CXXFLAGS) $< $(LEVELDB_LIB) -o $@ $(LDLIBS)

$(SCAN_BIN): leveldb_scan_test.cpp kv_cache.h $(LEVELDB_LIB) | $(BIN_DIR)
	$(CXX) $(CPPFLAGS) $(CXXFLAGS) $< $(LEVELDB_LIB) -o $@ $(LDLIBS)

$(MIXED_RW_BIN): leveldb_mixed_rw_test.cpp kv_cache.h $(LEVELDB_LIB) | $(BIN_DIR)
	$(CXX) $(CPPFLAGS) $(CXXFLAGS) $< $(LEVELDB_LIB) -o $@ $(LDLIBS)

$(C_TEST_BIN): $(OBJ_DIR)/db/c_test.o $(LEVELDB_LIB) | $(BIN_DIR)
	$(CXX) $^ -o $@ $(LDLIBS)

$(PORT_CONFIG): port/port_config.h.in | $(GEN_INCLUDE_DIR)/port
	@printf '%s\n' \
	  '// Generated by the top-level Makefile. Do not edit.' \
	  '#ifndef STORAGE_LEVELDB_PORT_PORT_CONFIG_H_' \
	  '#define STORAGE_LEVELDB_PORT_PORT_CONFIG_H_' \
	  '#if !defined(HAVE_FDATASYNC)' \
	  '#define HAVE_FDATASYNC 1' \
	  '#endif' \
	  '#if !defined(HAVE_FULLFSYNC)' \
	  '#define HAVE_FULLFSYNC 0' \
	  '#endif' \
	  '#if !defined(HAVE_O_CLOEXEC)' \
	  '#define HAVE_O_CLOEXEC 1' \
	  '#endif' \
	  '#if !defined(HAVE_CRC32C)' \
	  '#define HAVE_CRC32C 0' \
	  '#endif' \
	  '#if !defined(HAVE_SNAPPY)' \
	  '#define HAVE_SNAPPY 0' \
	  '#endif' \
	  '#if !defined(HAVE_ZSTD)' \
	  '#define HAVE_ZSTD 0' \
	  '#endif' \
	  '#endif' > $@

$(BIN_DIR) $(LIB_DIR) $(DATA_DIR) $(RESULT_DIR) $(GEN_INCLUDE_DIR)/port:
	@mkdir -p $@

clean:
	rm -rf "$(BUILD_DIR)" \
	  bench-logs db_bench_results.txt task2_run.log leveldb_task2_latency.csv \
	  leveldb_task2_db leveldb_task3_db leveldb_task3_block_db \
	  leveldb_task3_kv_db leveldb_task3_point_get_db leveldb_task3_scan_db \
	  leveldb_task3_quick_block_db leveldb_task3_quick_kv_db \
	  leveldb_task2_test leveldb_task3_test leveldb_point_get_test \
	  leveldb_scan_test leveldb_mixed_rw_test
